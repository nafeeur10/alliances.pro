# Root-level env example. Most service config lives in backend/.env and
# is wired through docker-compose.yml. Use this file for any host-level
# overrides if you need them.

# ---- Backend secrets passthrough -----------------------------------------
# (Set in backend/.env — these are placeholders only.)
# DB_PASSWORD=secret
# REDIS_PASSWORD=

# ---- Frontend (build-time) -----------------------------------------------
NEXT_PUBLIC_API_BASE=http://localhost/api/v1/marketing
NEXT_PUBLIC_SITE_URL=http://localhost
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
