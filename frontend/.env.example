# ----------------------------------------------------------------------------
# Public — exposed to the browser. Anything sensitive must NOT live here.
# ----------------------------------------------------------------------------

# Canonical URL for SEO + sitemap + OG image absolutization.
NEXT_PUBLIC_SITE_URL=https://alliances.pro

# Marketing API base — what client-side fetches (forms, etc.) hit.
NEXT_PUBLIC_API_BASE=https://alliances.pro/api/v1/marketing

# reCAPTCHA v3 site key (matches RECAPTCHA_SECRET in backend/.env).
# Leave empty in dev to skip reCAPTCHA.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Plausible analytics — leave NEXT_PUBLIC_PLAUSIBLE_DOMAIN unset to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=alliances.pro
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# Google Analytics 4 — leave NEXT_PUBLIC_GA_MEASUREMENT_ID unset to disable.
# Get this from Google Analytics → Admin → Data Streams → Web → Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token — paste the value from the
# "HTML tag" verification method (just the content="..." string).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Tawk.to live chat — leave NEXT_PUBLIC_TAWK_PROPERTY_ID unset to disable.
# After creating the Tawk property, copy the IDs from the embed snippet:
# https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=default

# ----------------------------------------------------------------------------
# Server-only — never prefixed with NEXT_PUBLIC_.
# ----------------------------------------------------------------------------

# Server-side API base used by RSC / generateStaticParams. In docker this
# points at the nginx service on the docker network. In Vercel / standalone
# deployments this should be the public API URL.
INTERNAL_API_URL=http://nginx/api/v1/marketing

# Override the API host for build-time `additionalPaths` fetches in
# next-sitemap.config.js (otherwise it derives from NEXT_PUBLIC_SITE_URL).
# MARKETING_API_URL=https://alliances.pro/api/v1/marketing
