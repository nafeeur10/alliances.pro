# Root-level gitignore for the alliances.pro marketing repo.
# App-specific ignores live in frontend/.gitignore and backend/.gitignore.

# OS / editors
.DS_Store
*.pem
.idea
.vscode
.fleet
.zed
.nova

# Local env
.env
.env.*.local
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
/build
/dist

# Frontend (kept here as a safety net; frontend/.gitignore is the primary)
frontend/node_modules
frontend/.next
frontend/out
frontend/.vercel
frontend/coverage
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Backend (kept here as a safety net; backend/.gitignore is the primary)
backend/vendor
backend/node_modules
backend/.env
backend/storage/*.key
backend/storage/logs/*.log
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/bootstrap/cache/*.php
backend/.phpunit.result.cache
