# ---- App ------------------------------------------------------------------
APP_NAME="Alliances PRO Marketing"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

# ---- Marketing site URL (used for canonicals, OG image, sitemap) ----------
MARKETING_SITE_URL=https://alliances.pro
MARKETING_NOTIFY_EMAIL=inafeeur@gmail.com

# ---- Allowed origins for the public marketing API (CORS) ------------------
APP_MARKETING_ORIGINS="http://localhost,http://localhost:3000,https://alliances.pro,https://www.alliances.pro"

# ---- Logging --------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- Database -------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=alliances_marketing
DB_USERNAME=alliances
DB_PASSWORD=secret

# ---- Cache / queue / session ---------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Mail (mailpit in dev, real SMTP in prod) -----------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@alliances.pro"
MAIL_FROM_NAME="${APP_NAME}"

# ---- File storage (S3 / DO Spaces in prod) --------------------------------
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---- reCAPTCHA v3 (contact / demo / waitlist forms) -----------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

# ---- Slack notifications (optional) ---------------------------------------
SLACK_MARKETING_WEBHOOK=

# ---- Filament admin -------------------------------------------------------
FILAMENT_FILESYSTEM_DISK=public

# ---- Error tracking (production) ------------------------------------------
# Set SENTRY_LARAVEL_DSN to start sending errors to Sentry. Leave empty in
# dev to skip. Sample-rate clamps cost — keep traces low in prod.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT="${APP_ENV}"
